{
  "name": "ComfyUI Anima RMBG Workflow",
  "category": "NVIDIA",
  "isPublic": false,
  "isServerless": false,
  "imageName": "ghcr.io/grawthings-beep/comfyui-anima-rmbg-workflow:cuda12.8",
  "containerDiskInGb": 40,
  "volumeInGb": 100,
  "volumeMountPath": "/workspace",
  "ports": [
    "8188/http"
  ],
  "dockerEntrypoint": [],
  "dockerStartCmd": [],
  "env": {
    "PORT": "8188",
    "LISTEN": "0.0.0.0",
    "WORKSPACE_DIR": "/workspace/comfyui",
    "MODEL_ROOT": "/workspace/comfyui",
    "HF_HOME": "/workspace/huggingface",
    "DOWNLOAD_MODELS": "1",
    "RUN_DEP_CHECK": "0",
    "HF_TOKEN": "{{ RUNPOD_SECRET_HF_TOKEN }}",
    "ARIA2_CONNECTIONS": "16",
    "ARIA2_SPLITS": "16",
    "COMFYUI_ARGS": "--reserve-vram 3"
  },
  "readme": "Docker image based on runpod/comfyui. Installs the Anima RMBG custom node and workflow, downloads only the WAI-ANIMA base, Qwen text encoder, Qwen image VAE, Anima Turbo LoRA, and Pixel CAME LoRA into /workspace/comfyui/models, then starts ComfyUI on port 8188."
}
