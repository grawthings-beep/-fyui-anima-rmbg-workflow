# Copy these into RunPod template environment variables as needed.

REPO_URL=https://github.com/grawthings-beep/-fyui-anima-rmbg-workflow.git
REPO_BRANCH=main
CUSTOM_NODE_DIR_NAME=ComfyUI-AnimaRmbgWorkflow

# Leave empty when the selected image stores ComfyUI at /workspace/ComfyUI.
COMFYUI_ROOT=
COMFYUI_PORT=8188
COMFYUI_REPO_URL=https://github.com/comfyanonymous/ComfyUI.git
COMFYUI_BRANCH=master
INSTALL_COMFYUI=1
INSTALL_COMFYUI_REQUIREMENTS=1

# Set RUN_BASE_START=1 only if your base image needs /start.sh for SSH/Jupyter
# and it does not already start ComfyUI itself.
START_COMFYUI=1
RUN_BASE_START=0
BASE_START_DELAY=2

INSTALL_NODE_REQUIREMENTS=1
UPDATE_REPO=1

# Keep this off unless the missing URLs in config/workflow-assets.json are filled
# or WORKFLOW_ASSET_SOURCE_ROOT points to another ComfyUI install containing the files.
INSTALL_WORKFLOW_ASSETS=0
WORKFLOW_ASSET_SOURCE_ROOT=
ALLOW_MISSING_WORKFLOW_ASSETS=0

# Prefer a RunPod secret for this value:
# HF_TOKEN={{ RUNPOD_SECRET_hf_token }}
HF_TOKEN=
