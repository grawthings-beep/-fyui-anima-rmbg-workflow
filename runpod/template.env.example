PORT=8188
LISTEN=0.0.0.0
WORKSPACE_DIR=/workspace/comfyui
MODEL_ROOT=/workspace/comfyui
DOWNLOAD_MODELS=1
RUN_DEP_CHECK=0
HF_TOKEN={{ RUNPOD_SECRET_HF_TOKEN }}
ARIA2_CONNECTIONS=16
ARIA2_SPLITS=16
COMFYUI_ARGS=--reserve-vram 3

# Optional: add extra models without replacing the base manifest.
# EXTRA_MODEL_MANIFEST_JSON={"models":[{"name":"Extra LoRA","enabled":true,"required":false,"method":"curl","url":"https://huggingface.co/OWNER/REPO/resolve/main/extra.safetensors","path":"models/loras/anima/extra.safetensors","headers":{"Authorization":"Bearer ${HF_TOKEN}"},"min_bytes":1048576}]}
